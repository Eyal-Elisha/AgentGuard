# Template: Copy this file to `.env` and fill in values.

# The base URL prefix for API calls
VITE_API_BASE_URL=

# The backend server URL for the Vite dev proxy
VITE_BACKEND_URL=

# Shown on Home (Proxy Control); defaults match backend PROXY_PORT when unset
VITE_PROXY_HOST=127.0.0.1
VITE_PROXY_PORT=8080