# Copy to `backend/.env` for local development.
# This is the single AgentGuard env file used by both the Flask backend and the proxy addon.

API_PORT=port-number
PROXY_PORT=port-number
AGENTGUARD_BACKEND_TIMEOUT_SECONDS=10
# Valid values: fail_closed, fail_open
AGENTGUARD_BACKEND_FAILURE_MODE=fail_closed
