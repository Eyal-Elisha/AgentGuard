# Template: copy to `backend/.env`, fill in values.

# Required. Use a long random secret
JWT_SECRET=

# Optional — leave blank to use application defaults (see README).
REQUIRE_AUTH=
FLASK_DEBUG=
PORT=
DATABASE_URL=

# Proxy addon → backend decision API (defaults: API host 127.0.0.1; port follows API_PORT or PORT)
API_HOST=
API_PORT=
PROXY_PORT=
AGENTGUARD_BACKEND_TIMEOUT_SECONDS=10
# Valid values: fail_closed, fail_open
AGENTGUARD_BACKEND_FAILURE_MODE=fail_closed
